# ============================================================
# Configuração do Extrator de Contratos
# Copie este arquivo para .env e preencha os valores
# ============================================================

# Anthropic API Key (obrigatório)
ANTHROPIC_API_KEY=sk-ant-...

# Modelo Claude a usar
# Opções: claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5-20251001
CLAUDE_EXTRACTION_MODEL=claude-sonnet-4-6
CLAUDE_ANALYSIS_MODEL=claude-sonnet-4-6

# Limite de tokens por chamada LLM
CLAUDE_MAX_TOKENS=8192

# Diretório de saída padrão
OUTPUT_DIR=output

# Nível de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# OCR - Caminho para o executável do Tesseract
# Windows: C:\Program Files\Tesseract-OCR\tesseract.exe
# Linux/Mac: /usr/bin/tesseract (geralmente no PATH)
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Idiomas do OCR (separados por +)
# por: Português | por+eng: Português + Inglês
OCR_LANG=por

# DPI para conversão PDF → imagem no OCR (maior = mais preciso, mais lento)
OCR_DPI=300

# Mínimo de caracteres por página para considerar texto nativo (vs OCR)
MIN_CHARS_NATIVE=100

# Máximo de tentativas para chamadas LLM em caso de falha
LLM_MAX_RETRIES=3

# Timeout em segundos para cada chamada LLM
LLM_TIMEOUT=120

# Salvar texto bruto extraído (útil para debug)
SAVE_RAW_TEXT=true
